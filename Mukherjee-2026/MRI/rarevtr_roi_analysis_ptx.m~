%% MAIN ANALYSIS FUNCTION                

function currSubjectPars = run_analysis(input_path_pre, input_path_post, cohort_number)

    % get subject summary information
    currSubjectPars = parse_subject_parameters(input_path_pre, cohort_number);
    currSubjectPars.PathToPre = input_path_pre;                                   
    currSubjectPars.PathToPost = input_path_post;
    fprintf('Processing subject %d... \n', currSubjectPars.ID);
        
    % get T1 distributions within ROIS pre- and post-ca injection
    T1HistogramsPre = segment_t1_map(input_path_pre);
    T1HistogramsPost = segment_t1_map(input_path_post);

        % compute wasserstein/earth mover's distance for each roi                          
    [~, currSubjectPars.EMDstriatum] = emd(T1HistogramsPre.BinSupport', ...
                                           T1HistogramsPost.BinSupport', ...
                                           T1HistogramsPre.Striatum', ...
                                           T1HistogramsPost.Striatum', ...
                                           @gdf);          

    [~, currSubjectPars.EMDthalamus] = emd(T1HistogramsPre.BinSupport', ...
                                           T1HistogramsPost.BinSupport', ...
                                           T1HistogramsPre.Thalamus', ...
                                           T1HistogramsPost.Thalamus', ...
                                           @gdf);   

    [~, currSubjectPars.EMDpssc] = emd(T1HistogramsPre.BinSupport', ...
                                           T1HistogramsPost.BinSupport', ...
                                           T1HistogramsPre.PrimarySSC', ...
                                           T1HistogramsPost.PrimarySSC', ...
                                           @gdf);   

    [~, currSubjectPars.EMDdg] = emd(T1HistogramsPre.BinSupport', ...
                                           T1HistogramsPost.BinSupport', ...
                                           T1HistogramsPre.DentateGyrus', ...
                                           T1HistogramsPost.DentateGyrus', ...
                                           @gdf);                                     
                                       
    % generate a summary figure
    generate_figure(currSubjectPars, T1HistogramsPre, T1HistogramsPost);                                       
                                       
    % save Pars and Histograms as .csv
    currSubjectPars = orderfields(currSubjectPars, [1 2 3 4 5 6 10 11 12 13 7 8 9]);
    fooTable = struct2table(currSubjectPars);
    writetable(fooTable, fullfile(currSubjectPars.PathToStudy, 't1_SubjectPars.csv'), 'delimiter',',');
    disp('Done.')
end

        
